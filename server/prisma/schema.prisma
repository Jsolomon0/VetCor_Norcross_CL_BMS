generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  role         String
  email        String   @unique
  passwordHash String?
  name         String
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  status      String   @default("pending_approval")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
